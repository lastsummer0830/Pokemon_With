# =========================
# OS / editor noise
# =========================
.DS_Store
Thumbs.db
*.swp
*.swo

# =========================
# VS Code
# - 공용 설정은 남기고, 개인별 로컬 파일만 무시
# =========================
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# =========================
# Local AI / agent workspace
# =========================
# AI 도구 설정·프롬프트·훅·계획은 공개 저장소에서 제외한다.
# (이전엔 .claude/skills·settings.json 을 PC 간 공유용으로 추적했으나 공개 노출 방지를 위해 중단)
.claude/
CLAUDE.md
AGENTS.md
.omo/
.sisyphus/
.playwright-mcp/

# =========================
# Secrets / local config
# =========================
.env
.env.*
!.env.example
!.env.*.example
config.properties
**/config.properties

# =========================
# JavaScript / TypeScript
# =========================
**/node_modules/
**/dist/
**/build/
**/.vite/
**/.cache/
**/coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# myPokemon_AJ: tsconfig에 outDir가 없어 tsc가 src 옆에 만든 산출물
myPokemon_AJ/src/**/*.js
myPokemon_AJ/src/**/*.js.map

# =========================
# Java / IDE build outputs
# =========================
**/target/
**/out/
**/bin/
**/.gradle/
*.class

# =========================
# Logs / temp
# =========================
*.log
*.tmp
*.bak

# =========================
# Reference images not needed for project sync
# =========================
01_Resources/Pokemon/

# =========================
# 로컬 실행 바로가기 (각자 빌드한 exe를 가리킴 — git엔 안 올림)
# =========================
*.lnk

# UI 렌더링 검증 증거(로컬 전용, .gitkeep만 추적)
.claude/.verify/*
!.claude/.verify/.gitkeep

# Python 훅 캐시 (session-guard 등)
__pycache__/
*.py[cod]
