{
  "name": "pokemon-with",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "하트골드 같은 2D 탑다운에 집 꾸미기 × 배틀을 연결한 포트폴리오 게임",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "fetch": "node tools/fetch-pokemon.mjs",
    "electron": "electron . --no-sandbox",
    "app": "concurrently -k -n vite,app \"vite\" \"wait-on tcp:127.0.0.1:5180 && electron . --no-sandbox\"",
    "app:build": "npm run build && electron-builder",
    "app:bake": "bash tools/bake-exe.sh"
  },
  "build": {
    "appId": "com.aj.pokemonwith",
    "productName": "PokemonWith",
    "directories": {
      "output": "build_win"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "dir",
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^25.1.8",
    "playwright": "^1.61.1",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "wait-on": "^9.0.10"
  }
}
