# 받아온 부품들 (npm install 하면 다시 생김)
node_modules/

# 빌드 결과물 (npm run build 하면 다시 생김)
dist/

# Electron 패키징 결과물 (exe 등, 용량 큼 — npm run app:build 하면 다시 생김)
# git엔 안 올림. 더블클릭 실행파일은 각자 로컬에서 빌드해서 씀.
release/
build_win/
build_new/
dist_electron/

# 로그·캐시
*.log
.DS_Store
.vite/

# 파이썬 도구(tools/) 바이트코드 캐시 — 실행하면 다시 생김
__pycache__/
*.pyc

# TypeScript가 no outDir 설정에서 src 옆에 만든 산출물
src/**/*.js
src/**/*.js.map

# UI 검증 산출물(로컬 전용)
.claude/.verify/
